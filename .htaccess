# 1. BẬT NÉN DỮ LIỆU (DEFLATE/GZIP)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript image/svg+xml
</IfModule>

# 2. CẤU HÌNH CACHE TRÌNH DUYỆT (EXPIRES)
<IfModule mod_expires.c>
    ExpiresActive On
    # Ảnh nghệ thuật: Lưu 1 năm (Vì ít khi thay đổi)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Font chữ: Lưu 1 năm (Giúp menu đứng yên ngay lập tức)
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # CSS & Javascript: Lưu 1 tháng
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    ExpiresDefault "access plus 2 days"
</IfModule>

# 3. MỞ KHÓA FONT CHỮ (CORS)
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font.css)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
    
    # Bảo mật: Ngăn chặn trình duyệt đoán định dạng file
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# 4. TỐI ƯU HÓA REWRITE (Nếu cần thiết cho Piwigo)
Options -Indexes
